# PostgreSQL (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/paltech_forge?schema=public"

# Auth.js / NextAuth (JWT sessions)
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3000"

# Google OAuth (optional)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Optional: separate secret for custom API JWTs (see src/lib/jwt.ts)
JWT_SECRET="replace-with-a-different-long-random-secret"
